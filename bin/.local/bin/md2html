UI_JS = r"""
(function () {
  // 浮动目录: 开合 + 点击外部关闭 + 滚动高亮当前章节
  var btn = document.querySelector('.toc-btn');
  var panel = document.querySelector('.toc-panel');
  if (btn && panel) {
    btn.addEventListener('click', function (e) { e.stopPropagation(); panel.classList.toggle('open'); });
    var links = {};
    panel.querySelectorAll('a').forEach(function (a) {
      links[a.getAttribute('href').slice(1)] = a;
      a.addEventListener('click', function () { panel.classList.remove('open'); });
    });
    document.addEventListener('click', function (e) {
      if (!panel.contains(e.target) && e.target !== btn) panel.classList.remove('open');
    });
    var io = new IntersectionObserver(function (es) {
      es.forEach(function (e) {
        if (!e.isIntersecting) return;
        Object.keys(links).forEach(function (k) { links[k].classList.remove('active'); });
        if (links[e.target.id]) links[e.target.id].classList.add('active');
      });
    }, { rootMargin: '0px 0px -78% 0px' });
    document.querySelectorAll('h2[id],h3[id]').forEach(function (h) { io.observe(h); });
  }

  // 图表灯箱: 点击放大, 滚轮缩放, 拖拽平移
  var lb = document.getElementById('lb');
  if (!lb) return;
  var inner = lb.querySelector('.lb-inner');
  var scale = 1, tx = 0, ty = 0, drag = false, sx = 0, sy = 0;
  function apply() {
    var el = inner.firstChild;
    if (el) el.style.transform = 'translate(' + tx + 'px,' + ty + 'px) scale(' + scale + ')';
  }
  function open(svg) {
    var stage = document.createElement('div');
    stage.className = 'lb-stage';
    stage.style.transformOrigin = 'center center';
    var clone = svg.cloneNode(true);
    clone.removeAttribute('style');
    stage.appendChild(clone);
    inner.innerHTML = '';
    inner.appendChild(stage);
    lb.classList.add('open');
    var r = stage.getBoundingClientRect();
    scale = Math.min(window.innerWidth * 0.9 / r.width, window.innerHeight * 0.9 / r.height, 3) || 1;
    tx = 0; ty = 0; apply();
  }
  function close() { lb.classList.remove('open'); }
  document.querySelectorAll('pre.mermaid').forEach(function (pre) {
    pre.addEventListener('click', function () {
      var svg = pre.querySelector('svg'); if (svg) open(svg);
    });
  });
  lb.querySelector('.lb-close').addEventListener('click', close);
  lb.addEventListener('click', function (e) { if (e.target === lb) close(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
  lb.addEventListener('wheel', function (e) {
    e.preventDefault();
    scale = Math.min(10, Math.max(0.2, scale * (e.deltaY < 0 ? 1.12 : 1 / 1.12)));
    apply();
  }, { passive: false });
  inner.addEventListener('pointerdown', function (e) {
    drag = true; sx = e.clientX - tx; sy = e.clientY - ty; inner.setPointerCapture(e.pointerId);
  });
  inner.addEventListener('pointermove', function (e) {
    if (drag) { tx = e.clientX - sx; ty = e.clientY - sy; apply(); }
  });
  inner.addEventListener('pointerup', function () { drag = false; });
})();
"""


def convert(src: Path, out: Path | None, use_cdn: bool, elk_default: bool,
            no_toc: bool, font_key: str) -> Path:
    raw = src.read_text(encoding="utf-8")
    text, meta = split_front_matter(raw)
    text = replace_wikilinks(text)
    title = extract_title(text, src.stem)
    need_elk = (
        elk_default
        or bool(re.search(r"layout:\s*elk", text))
        or bool(re.search(r"%%\s*elk\s*%%", text))
    )
    env: dict = {}
    body = wrap_tables(MD.render(transform_callouts(text), env))
    header = meta_header(meta)
    if header:
        if "</h1>" in body:
            body = body.replace("</h1>", "</h1>\n" + header, 1)
        else:
            body = header + body
    if not no_toc:
        body += build_toc(env.get("toc", []))
    dest = out or src.with_suffix(".html")
    dest.write_text(
        page(title, body, use_cdn, elk_default, need_elk, font_key, text),
        encoding="utf-8",
    )
    return dest


def main() -> None:
    ap = argparse.ArgumentParser(
        description="markdown(含 mermaid/callout) → Anthropic 品牌风自包含 HTML"
    )
    ap.add_argument("inputs", nargs="+", type=Path, help="一个或多个 .md 文件")
    ap.add_argument("-o", "--output", type=Path, help="输出路径(仅单文件时有效)")
    ap.add_argument("--elk", action="store_true", help="所有流程图默认用 ELK 布局")
    ap.add_argument("--no-toc", action="store_true", help="关闭自动目录")
    ap.add_argument("--cdn", action="store_true", help="mermaid/字体走 CDN 而非内联")
    ap.add_argument("--font", choices=[*CJK_FONTS, "none"], default="lxgw",
                    help="内嵌中文字体(按用字子集化), 默认 lxgw; maple=另一款; none=系统字体")
    args = ap.parse_args()

    if args.output and len(args.inputs) > 1:
        ap.error("-o 只能配合单个输入文件使用")

    for src in args.inputs:
        if not src.exists():
            print(f"  ! 跳过不存在的文件: {src}", file=sys.stderr)
            continue
        dest = convert(src, args.output, args.cdn, args.elk, args.no_toc, args.font)
        print(f"  ✓ {src} → {dest}")


if __name__ == "__main__":
    main()
