#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = [
#     "markdown-it-py>=3",
#     "mdit-py-plugins>=0.4",
#     "linkify-it-py>=2",
#     "pygments>=2.17",
#     "fonttools>=4.50",
#     "brotli>=1.1",
# ]
# ///
"""md2html — markdown(含 mermaid / Obsidian callout) → 自包含单文件 HTML(暖色品牌观感)。

用法:
    md2html 文档.md               # 旁边生成 文档.html (默认内嵌 LXGW 楷体)
    md2html 文档.md -o 成品.html   # 指定输出
    md2html a.md b.md             # 批量
    md2html 文档.md --font maple  # 换 Maple Mono CN; --font none 用系统字体
    md2html 文档.md --elk         # 所有流程图默认用 ELK 布局
    md2html 文档.md --no-toc      # 关闭浮动目录
    md2html 文档.md --cdn         # mermaid 走 CDN(文件更小,打开需联网)

单张图想用 ELK: 在该 mermaid 块顶部写 `%% elk %%`, 或加 frontmatter
    ---
    config:
      layout: elk
    ---
"""
from __future__ import annotations

import argparse
import base64
import html
import re
import subprocess
import sys
import tempfile
import urllib.request
from pathlib import Path

from markdown_it import MarkdownIt
from mdit_py_plugins.footnote import footnote_plugin
from mdit_py_plugins.tasklists import tasklists_plugin
from pygments import highlight as pyg_highlight
from pygments.formatters import HtmlFormatter
from pygments.lexers import get_lexer_by_name
from pygments.util import ClassNotFound

MERMAID_VER = "11"
MERMAID_URL = f"https://cdn.jsdelivr.net/npm/mermaid@{MERMAID_VER}/dist/mermaid.min.js"
ELK_PKG = "@mermaid-js/layout-elk@0.2.2"
FONT_WEIGHTS = (600, 700)
FONT_URL = "https://cdn.jsdelivr.net/npm/@fontsource/poppins@5/files/poppins-latin-{w}-normal.woff2"
CACHE_DIR = Path.home() / ".cache" / "md2html"

# 可选中文字体(全量 TTF 下载一次, 按文档用字子集化后内嵌 woff2)
CJK_FONTS = {
    "lxgw": {
        "family": "LXGW WenKai Mono Screen",
        "file": "LXGWWenKaiMonoScreen.ttf",
        "url": "https://github.com/lxgw/LxgwWenKai-Screen/releases/download/v1.522/LXGWWenKaiMonoScreen.ttf",
    },
    "maple": {
        "family": "Maple Mono CN",
        "file": "MapleMono-CN-Regular.ttf",
        "zip_url": "https://github.com/subframe7536/maple-font/releases/download/v7.9/MapleMono-CN.zip",
        "zip_member": "MapleMono-CN-Regular.ttf",
    },
}

# ── Obsidian callout 类型 → (emoji, 主题色) ─────────────────────────────
CALLOUTS = {
    "note": ("✏️", "#6a9bcc"), "info": ("ℹ️", "#6a9bcc"),
    "tip": ("💡", "#788c5d"), "hint": ("💡", "#788c5d"), "important": ("🔔", "#788c5d"),
    "success": ("✅", "#788c5d"), "check": ("✅", "#788c5d"), "done": ("✅", "#788c5d"),
    "question": ("❓", "#c99a2e"), "faq": ("❓", "#c99a2e"),
    "warning": ("⚠️", "#d97757"), "caution": ("⚠️", "#d97757"), "attention": ("⚠️", "#d97757"),
    "danger": ("🔥", "#c0392b"), "error": ("🔥", "#c0392b"), "failure": ("❌", "#c0392b"),
    "bug": ("🐛", "#c0392b"),
    "example": ("📋", "#8a7bb0"), "quote": ("💬", "#b0aea5"), "cite": ("💬", "#b0aea5"),
    "abstract": ("📄", "#6a9bcc"), "summary": ("📄", "#6a9bcc"), "tldr": ("📄", "#6a9bcc"),
}


# ────────────────────────── markdown 引擎 ──────────────────────────────
def slugify(text: str) -> str:
    text = re.sub(r"<[^>]+>", "", text)
    text = re.sub(r"[*`_~]", "", text).strip().lower()
    text = re.sub(r"[^\w一-鿿\- ]", "", text)
    text = re.sub(r"\s+", "-", text)
    return text or "section"


def normalize_mermaid(code: str) -> str:
    """识别 `%% elk %%` 标记(或 layout: elk), 剥离标记并把 layout: elk 真正注入 frontmatter。"""
    wants = bool(re.search(r"%%\s*elk\s*%%", code)) or bool(re.search(r"layout:\s*elk", code))
    code = re.sub(r"(?m)^\s*%%\s*elk\s*%%\s*$\n?", "", code)
    if wants and not re.search(r"layout:\s*elk", code):
        if code.lstrip().startswith("---"):
            if re.search(r"(?m)^config:\s*$", code):
                code = re.sub(r"(?m)^(config:\s*)$", r"\1\n  layout: elk", code, count=1)
            else:
                code = re.sub(r"^(\s*---\s*\n)", r"\1config:\n  layout: elk\n", code, count=1)
        else:
            code = "---\nconfig:\n  layout: elk\n---\n" + code
    return code


def highlight_code(code: str, lang: str, attrs: str) -> str:
    if lang == "mermaid":
        return f'<pre class="mermaid">{html.escape(normalize_mermaid(code))}</pre>'
    lexer = None
    if lang:
        try:
            lexer = get_lexer_by_name(lang, stripnl=False)
        except ClassNotFound:
            lexer = None
    label = f'<span class="code-lang">{html.escape(lang)}</span>' if lang else ""
    if lexer is None:
        return f'<pre class="code-block">{label}<code>{html.escape(code)}</code></pre>'
    inner = pyg_highlight(code, lexer, HtmlFormatter(nowrap=True))
    return f'<pre class="code-block">{label}<code>{inner}</code></pre>'


def _heading_open(tokens, idx, options, env):
    """给标题注入稳定的 id(含中文), 并收集 TOC。"""
    token = tokens[idx]
    plain = html.unescape(re.sub(r"<[^>]+>", "", MD.renderInline(tokens[idx + 1].content))).strip()
    base = slugify(plain)
    seen = env.setdefault("slugs", {})
    n = seen.get(base, 0)
    seen[base] = n + 1
    uid = base if n == 0 else f"{base}-{n}"
    level = int(token.tag[1])
    env.setdefault("toc", []).append((level, plain, uid))
    return f'<{token.tag} id="{uid}">'


def build_md() -> MarkdownIt:
    md = MarkdownIt(
        "js-default",
        {"html": True, "linkify": True, "typographer": True, "highlight": highlight_code},
    )
    md.use(footnote_plugin)
    md.use(tasklists_plugin, enabled=True, label=True)
    md.renderer.rules["heading_open"] = _heading_open
    return md


MD = build_md()

# ── frontmatter / wikilink ──────────────────────────────────────────────
def split_front_matter(text: str) -> tuple[str, dict]:
    m = re.match(r"^---\s*\n(.*?)\n---\s*\n", text, re.DOTALL)
    if not m:
        return text, {}
    fm, body = m.group(1), text[m.end():]
    meta: dict = {}
    tm = re.search(r"(?m)^updated:\s*(.+)$", fm)
    if tm:
        meta["updated"] = tm.group(1).strip().strip("\"'")
    tg = re.search(r"tags:\s*\[([^\]]+)\]", fm, re.DOTALL)
    if tg:
        meta["tags"] = [t.strip().strip("\"'") for t in tg.group(1).split(",") if t.strip()]
    return body, meta


def meta_header(meta: dict) -> str:
    bits = []
    if meta.get("tags"):
        chips = "".join(f'<span class="tag">{html.escape(t)}</span>' for t in meta["tags"])
        bits.append(f'<span class="meta-tags">{chips}</span>')
    if meta.get("updated"):
        bits.append(f'<span class="meta-date">更新于 {html.escape(meta["updated"])}</span>')
    return f'<div class="doc-meta">{"".join(bits)}</div>' if bits else ""


_WIKILINK = re.compile(r"\[\[([^\[\]|#]+)(?:#[^\[\]|]+)?(?:\|([^\[\]]+))?\]\]")


def _wl(m: re.Match) -> str:
    alias = (m.group(2) or m.group(1)).strip()
    return f'<span class="wikilink">{html.escape(alias)}</span>'


def replace_wikilinks(text: str) -> str:
    out, in_fence = [], False
    for line in text.split("\n"):
        s = line.lstrip()
        if s.startswith("```") or s.startswith("~~~"):
            in_fence = not in_fence
            out.append(line)
        elif in_fence:
            out.append(line)
        else:
            out.append(_WIKILINK.sub(_wl, line))
    return "\n".join(out)


_CALLOUT_HEAD = re.compile(r"^>\s*\[!(\w+)\]([+-]?)\s?(.*)$")


def transform_callouts(text: str) -> str:
    lines = text.split("\n")
    out: list[str] = []
    i = 0
    while i < len(lines):
        m = _CALLOUT_HEAD.match(lines[i])
        if not m:
            out.append(lines[i])
            i += 1
            continue
        ctype = m.group(1).lower()
        title_raw = m.group(3).strip()
        body: list[str] = []
        i += 1
        while i < len(lines) and lines[i].startswith(">"):
            body.append(re.sub(r"^>\s?", "", lines[i]))
            i += 1
        emoji, color = CALLOUTS.get(ctype, CALLOUTS["note"])
        title_html = MD.renderInline(title_raw) if title_raw else ctype.capitalize()
        body_html = MD.render(transform_callouts("\n".join(body)), {}) if body else ""
        out.append("")
        out.append(
            f'<div class="callout" style="--cc:{color}">'
            f'<div class="callout-title"><span class="callout-icon">{emoji}</span>'
            f"<span>{title_html}</span></div>"
            f'<div class="callout-content">{body_html}</div></div>'
        )
        out.append("")
    return "\n".join(out)


def build_toc(toc: list[tuple[int, str, str]]) -> str:
    items = [t for t in toc if t[0] in (2, 3)]
    if len(items) < 3:
        return ""
    lis = "".join(
        f'<li class="toc-l{lvl}"><a href="#{uid}">{html.escape(txt)}</a></li>'
        for lvl, txt, uid in items
    )
    return (
        '<button class="toc-btn" aria-label="切换目录">☰ 目录</button>'
        f'<nav class="toc-panel"><div class="toc-title">目录</div><ul>{lis}</ul></nav>'
    )


def wrap_tables(h: str) -> str:
    return h.replace("<table>", '<div class="table-wrap"><table>').replace(
        "</table>", "</table></div>"
    )


def extract_title(text: str, fallback: str) -> str:
    for line in text.split("\n"):
        m = re.match(r"^#\s+(.*)$", line)
        if m:
            return re.sub(r"[*`_]", "", m.group(1)).strip() or fallback
    return fallback


# ────────────────────────── 资源(字体/mermaid/elk) ─────────────────────
def cached_download(url: str, name: str) -> bytes | None:
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    cache = CACHE_DIR / name
    if cache.exists():
        return cache.read_bytes()
    try:
        with urllib.request.urlopen(url, timeout=40) as r:
            data = r.read()
        cache.write_bytes(data)
        return data
    except Exception as e:  # noqa: BLE001
        print(f"  ! 下载失败 {name} ({e})", file=sys.stderr)
        return None


def font_css(use_cdn: bool) -> str:
    if use_cdn:
        faces = "".join(
            f"@font-face{{font-family:'Poppins';font-weight:{w};font-style:normal;"
            f"font-display:swap;src:url({FONT_URL.format(w=w)}) format('woff2')}}"
            for w in FONT_WEIGHTS
        )
        return faces
    faces = []
    for w in FONT_WEIGHTS:
        data = cached_download(FONT_URL.format(w=w), f"poppins-{w}.woff2")
        if data is None:
            print(f"  ! Poppins {w} 不可用, 标题回退系统字体", file=sys.stderr)
            continue
        b64 = base64.b64encode(data).decode()
        faces.append(
            f"@font-face{{font-family:'Poppins';font-weight:{w};font-style:normal;"
            f"font-display:swap;src:url(data:font/woff2;base64,{b64}) format('woff2')}}"
        )
    return "".join(faces)


_CJK_PUNCT = "，。、；：？！“”‘’（）〔〕【】《》〈〉「」『』—…·　％＃＠～｜／＜＞"


def font_ttf_bytes(spec: dict) -> bytes | None:
    """取字体全量 TTF: 直链 direct 下载, 或从 release zip 提取指定成员(仅解出的 TTF 入缓存)。"""
    cache = CACHE_DIR / spec["file"]
    if cache.exists():
        return cache.read_bytes()
    if not spec.get("zip_url"):
        return cached_download(spec["url"], spec["file"])
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    print("  ↓ 首次下载字体压缩包(较大, 仅此一次)…", file=sys.stderr)
    try:
        import io
        import zipfile

        with urllib.request.urlopen(spec["zip_url"], timeout=180) as r:
            zf = zipfile.ZipFile(io.BytesIO(r.read()))
        member = next((n for n in zf.namelist() if n.endswith(spec["zip_member"])), None)
        if not member:
            print(f"  ! zip 内未找到 {spec['zip_member']}", file=sys.stderr)
            return None
        ttf = zf.read(member)
    except Exception as e:  # noqa: BLE001
        print(f"  ! 字体压缩包获取失败({e})", file=sys.stderr)
        return None
    cache.write_bytes(ttf)
    return ttf


def cjk_font_css(font_key: str, text: str) -> str:
    """取指定中文字体全量 TTF, 按 text 用字子集化成 woff2 内嵌, 返回 @font-face + 变量覆盖。"""
    spec = CJK_FONTS.get(font_key)
    if not spec:
        return ""
    data = font_ttf_bytes(spec)
    if data is None:
        print(f"  ! 字体 {spec['family']} 获取失败, 回退默认字体", file=sys.stderr)
        return ""
    try:
        import io

        from fontTools.subset import Options, Subsetter
        from fontTools.ttLib import TTFont

        opt = Options()
        opt.flavor = "woff2"
        opt.desubroutinize = True
        opt.name_IDs = ["*"]
        opt.recalc_bounds = True
        font = TTFont(io.BytesIO(data))
        ss = Subsetter(options=opt)
        chars = text + _CJK_PUNCT + "".join(chr(c) for c in range(0x20, 0x7F))
        ss.populate(text=chars)
        ss.subset(font)
        buf = io.BytesIO()
        font.save(buf)
        woff2 = buf.getvalue()
    except Exception as e:  # noqa: BLE001
        print(f"  ! 字体子集化失败({e}), 回退默认字体", file=sys.stderr)
        return ""
    fam = spec["family"]
    b64 = base64.b64encode(woff2).decode()
    print(f"  ♦ 内嵌 {fam}: 子集 {len(woff2) // 1024} KB", file=sys.stderr)
    fallback = '"PingFang SC", "Microsoft YaHei", sans-serif'
    return (
        f"@font-face{{font-family:'{fam}';font-weight:400;font-style:normal;"
        f"font-display:swap;src:url(data:font/woff2;base64,{b64}) format('woff2')}}"
        f":root{{--font-body:'{fam}',{fallback};--font-head:'{fam}',{fallback};"
        f"--font-mono:'{fam}',ui-monospace,monospace}}"
    )


def mermaid_asset(use_cdn: bool) -> str:
    if use_cdn:
        return f'<script src="{MERMAID_URL}"></script>'
    data = cached_download(MERMAID_URL, f"mermaid-{MERMAID_VER}.min.js")
    if data is None:
        return f'<script src="{MERMAID_URL}"></script>'
    return f"<script>{data.decode('utf-8')}</script>"


def elk_asset() -> str | None:
    """返回内联的 ELK 布局包(自包含 IIFE, 暴露 window.__elkLayouts); 缺失则用 esbuild 现打并缓存。"""
    dst = CACHE_DIR / "mermaid-elk.min.js"
    if dst.exists():
        return f"<script>{dst.read_text(encoding='utf-8')}</script>"
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    print("  ↻ 首次使用 ELK: 用 esbuild 打包(需 node, 仅此一次)…", file=sys.stderr)
    try:
        with tempfile.TemporaryDirectory() as d:
            Path(d, "entry.js").write_text(
                "import elk from '@mermaid-js/layout-elk';\nwindow.__elkLayouts = elk;\n"
            )
            run = lambda *a: subprocess.run(a, cwd=d, check=True, capture_output=True)  # noqa: E731
            run("npm", "init", "-y")
            run("npm", "i", ELK_PKG)
            run("npx", "--yes", "esbuild", "entry.js", "--bundle",
                "--format=iife", "--minify", "--outfile=out.js")
            js = Path(d, "out.js").read_text()
        dst.write_text(js)
        return f"<script>{js}</script>"
    except Exception as e:  # noqa: BLE001
        print(f"  ! ELK 打包失败({e}), 该文档流程图回退默认布局", file=sys.stderr)
        return None


# ────────────────────────── 页面模板 ───────────────────────────────────
def page(title: str, body: str, use_cdn: bool, elk_default: bool, need_elk: bool,
         font_key: str, doc_text: str) -> str:
    light_hl = HtmlFormatter(style="default").get_style_defs(".code-block")
    dark_hl = HtmlFormatter(style="monokai").get_style_defs(".code-block")
    elk_js = elk_asset() if need_elk else None
    layout_line = "layout: 'elk'," if (elk_default and elk_js) else ""
    custom_font = cjk_font_css(font_key, doc_text) if font_key else ""
    return f"""<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{html.escape(title)}</title>
<style>
{"" if custom_font else font_css(use_cdn)}
{BASE_CSS}
{custom_font}
@media (prefers-color-scheme: light) {{ {light_hl} }}
@media (prefers-color-scheme: dark)  {{ {dark_hl} }}
</style>
</head>
<body>
<main class="doc">
{body}
</main>
<div class="lb" id="lb"><span class="lb-close">✕</span>
  <div class="lb-hint">滚轮缩放 · 拖拽平移 · Esc 关闭</div>
  <div class="lb-inner"></div></div>
{mermaid_asset(use_cdn)}
{elk_js or ""}
<script>
  const dark = matchMedia('(prefers-color-scheme: dark)').matches;
  const vars = dark ? {MERMAID_DARK} : {MERMAID_LIGHT};
  if (window.__elkLayouts) mermaid.registerLayoutLoaders(window.__elkLayouts);
  mermaid.initialize({{
    startOnLoad: true, theme: 'base', themeVariables: vars,
    securityLevel: 'loose', {layout_line}
    flowchart: {{ curve: 'basis', useMaxWidth: true }}
  }});
</script>
<script>{UI_JS}</script>
</body>
</html>
"""


_MMFONT = ('-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, '
           '"PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif')

MERMAID_LIGHT = """{
  fontFamily: '""" + _MMFONT + """', fontSize: '15px',
  primaryColor: '#efe6d6', primaryBorderColor: '#d2643f', primaryTextColor: '#141311',
  lineColor: '#b9ad95', secondaryColor: '#e4ddcf', tertiaryColor: '#f4f0e8',
  noteBkgColor: '#efe6d6', noteBorderColor: '#d2643f', noteTextColor: '#141311',
  actorBkg: '#efe6d6', actorBorder: '#d2643f', clusterBkg: '#efe9dd', clusterBorder: '#d6cdba'
}"""

MERMAID_DARK = """{
  fontFamily: '""" + _MMFONT + """', fontSize: '15px', darkMode: true,
  primaryColor: '#26221b', primaryBorderColor: '#e5825c', primaryTextColor: '#f0ebe2',
  lineColor: '#6b6459', secondaryColor: '#1d1a16', tertiaryColor: '#14120f',
  noteBkgColor: '#26221b', noteBorderColor: '#e5825c', noteTextColor: '#f0ebe2',
  actorBkg: '#26221b', actorBorder: '#e5825c', clusterBkg: '#1d1a16', clusterBorder: '#2c2822'
}"""


BASE_CSS = """
:root {
  --bg: #f4f0e8; --fg: #141311; --muted: #7c746a; --border: #e4ddcf;
  --accent: #d2643f; --accent-2: #5a86b8; --accent-3: #6a9c58;
  --code-bg: #ece4d5; --card: #fffdf8;
  --measure: 67.5rem; --fig: min(95vw, 80rem);
  --font-head: 'Poppins', -apple-system, BlinkMacSystemFont, "Segoe UI",
    "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  --font-body: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
    "Helvetica Neue", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  --font-mono: ui-monospace, "SF Mono", "JetBrains Mono", "Fira Code", Menlo, Consolas, monospace;
}
@media (prefers-color-scheme: dark) {
  :root {
    --bg: #14120f; --fg: #f0ebe2; --muted: #8f867a; --border: #2c2822;
    --accent: #e5825c; --accent-2: #7aa5d4; --accent-3: #84b56f;
    --code-bg: #211d17; --card: #1d1a16;
  }
}
* { box-sizing: border-box; }
html { -webkit-text-size-adjust: 100%; }
body {
  margin: 0; background: var(--bg); color: var(--fg); font-family: var(--font-body);
  font-size: 17px; line-height: 1.8; font-feature-settings: "kern", "liga";
  -webkit-font-smoothing: antialiased;
}
html { scroll-behavior: smooth; }
/* full-bleed 网格: 正文居中于 content 轨(measure), 图表/表格跨满整幅(fig) */
.doc {
  display: grid;
  grid-template-columns:
    [full-start] minmax(0, 1fr)
    [content-start] min(var(--measure), 100% - 3rem) [content-end]
    minmax(0, 1fr) [full-end];
  max-width: var(--fig); margin: 0 auto; padding: 4rem 0 6rem;
}
.doc > * { grid-column: content; }
.doc > .table-wrap, .doc > pre.mermaid { grid-column: full; }
.doc > *:first-child { margin-top: 0; }
h2[id], h3[id], h4[id] { scroll-margin-top: 1.5rem; }

