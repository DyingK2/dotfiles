#!/usr/bin/env python3
"""Split a file into chunks <5MB, then merge them back."""
import sys
import hashlib
from pathlib import Path

DEFAULT_CHUNK = 4 * 1024 * 1024
MAX_CHUNK = 5 * 1024 * 1024 - 1


def split_file(src: str, chunk_size: int = DEFAULT_CHUNK) -> None:
    src_path = Path(src)
    if not src_path.is_file():
        sys.exit(f"error: {src} is not a file")
    if chunk_size > MAX_CHUNK:
        sys.exit(f"error: chunk size {chunk_size} exceeds 5MB limit")

    out_dir = src_path.parent / f"{src_path.name}.parts"
    out_dir.mkdir(exist_ok=True)

    md5 = hashlib.md5()
    index = 0
    with src_path.open("rb") as f:
        while True:
            chunk = f.read(chunk_size)
            if not chunk:
                break
            md5.update(chunk)
            part = out_dir / f"{src_path.name}.part{index:04d}"
            part.write_bytes(chunk)
            print(f"  {part.name}  {len(chunk):,} bytes")
            index += 1

    (out_dir / "manifest.txt").write_text(
        f"filename: {src_path.name}\n"
        f"parts: {index}\n"
        f"size: {src_path.stat().st_size}\n"
        f"md5: {md5.hexdigest()}\n"
    )
    print(f"\nsplit into {index} parts -> {out_dir}/")


def merge_file(parts_dir: str, out: str | None = None) -> None:
    dir_path = Path(parts_dir)
    if not dir_path.is_dir():
        sys.exit(f"error: {parts_dir} is not a directory")

    info: dict[str, str] = {}
    manifest = dir_path / "manifest.txt"
    if manifest.exists():
        for line in manifest.read_text().splitlines():
            k, _, v = line.partition(":")
            info[k.strip()] = v.strip()

    parts = sorted(p for p in dir_path.glob("*.part*") if p.is_file())
    if not parts:
        sys.exit(f"error: no parts found in {parts_dir}")

    if out is None:
        name = info.get("filename") or dir_path.name.replace(".parts", ".restored")
        out_path = dir_path.parent / name
    else:
        out_path = Path(out)

    md5 = hashlib.md5()
    with out_path.open("wb") as fout:
        for part in parts:
            data = part.read_bytes()
            md5.update(data)
            fout.write(data)
            print(f"  + {part.name}")

    print(f"\nmerged -> {out_path}")
    expected = info.get("md5")
    if expected:
        actual = md5.hexdigest()
        if actual == expected:
            print(f"md5 ok: {actual}")
        else:
            sys.exit(f"WARNING: md5 mismatch (expected {expected}, got {actual})")


def usage() -> None:
    print("usage:")
    print("  filesplit split <file> [chunk_size_mb]   # default 4 MB, max <5 MB")
    print("  filesplit merge <parts_dir> [out_file]")
    sys.exit(1)


def main() -> None:
    if len(sys.argv) < 3:
        usage()
    cmd = sys.argv[1]
    if cmd == "split":
        size = DEFAULT_CHUNK
        if len(sys.argv) >= 4:
            size = int(float(sys.argv[3]) * 1024 * 1024)
        split_file(sys.argv[2], size)
    elif cmd == "merge":
        out = sys.argv[3] if len(sys.argv) >= 4 else None
        merge_file(sys.argv[2], out)
    else:
        usage()


if __name__ == "__main__":
    main()
