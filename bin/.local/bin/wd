#!/usr/bin/env bash
# wd — 快速查词:离线 ECDICT(sdcv)为主,trans 在线兜底。
# 三入口三模式,各自确定性:
#   wd [word…]   终端:参数,无参数落选区/剪贴板,stdout 输出
#   wd --notify  划词键(Mod+Shift+D):选区/剪贴板 → mako 弹出
#   wd --ask     手输键(Mod+Ctrl+D):直接 fuzzel 输入框 → mako 弹出
# Wayland 选区不会因取消选中而清空,「无选中」不可探测——所以手输不与划词共键,
# 划词键的语义就是「查当前选区里的东西」,重按重显。
set -uo pipefail

DATA_DIR="$HOME/.local/share/stardict"
MEMO="${XDG_RUNTIME_DIR:-/tmp}/wd-last"
MODE=cli
case "${1:-}" in
    --notify) MODE=notify; shift ;;
    --ask)    MODE=ask;    shift ;;
esac

trim() {
    # 先折叠所有空白(含换行)为单空格,再剥首尾空白/标点;命令替换会吃掉 sed 的结尾换行
    tr -s '[:space:]' ' ' <<<"$1" | sed -E 's/^[[:space:][:punct:]]+//; s/[[:space:][:punct:]]+$//'
}

get_query() {
    local q last="" pri clip
    if [[ $MODE == ask ]]; then
        trim "$(fuzzel --dmenu --prompt-only='查词 ' 2>/dev/null || true)"
        return
    fi
    q="$(trim "$*")"
    if [[ -z "$q" ]]; then
        [[ -f "$MEMO" ]] && last="$(<"$MEMO")"
        pri="$(trim "$(wl-paste -p -n 2>/dev/null || true)")"
        clip="$(trim "$(wl-paste -n 2>/dev/null || true)")"
        # 剪贴板只为吃 zathura 的英文划词:非 ASCII(中文等)或 >5 词的一律视为噪音
        if [[ "$clip" == *[![:ascii:]]* ]] || (( $(wc -w <<<"$clip") > 5 )); then
            clip=""
        fi
        if [[ -n "$pri" && "$pri" != "$last" ]]; then
            q="$pri"                     # 新选区优先
        elif [[ -n "$clip" && "$clip" != "$last" ]]; then
            q="$clip"                    # 选区已消费,吃新剪贴板(zathura 路)
        else
            q="$pri"                     # 都不新鲜:重显选区(重按重显,确定性)
        fi
    fi
    printf '%s' "$q"
}

lookup_offline() {  # $1=word;未命中/无 sdcv 返回非零
    command -v sdcv >/dev/null || return 1
    sdcv --data-dir "$DATA_DIR" -n --json "$1" 2>/dev/null | python3 -c '
import json, sys
r = json.load(sys.stdin)
if not r: sys.exit(1)
print(r[0]["definition"].strip())'
}

lookup_online() {  # $1=text
    timeout 8 trans -b :zh "$1" 2>/dev/null
}

show() {  # $1=标题 $2=正文;通知端截 20 行防溢出
    local body="$2"
    if [[ $MODE == cli ]]; then
        printf '%s\n%s\n' "$1" "$body"
    else
        local capped
        capped="$(head -n 20 <<<"$body")"
        [[ "$capped" != "$body" ]] && capped+=$'\n…'
        notify-send -a wd -t 10000 "$1" "$capped"
    fi
}

q="$(get_query "$@")"
if [[ -z "$q" ]]; then
    [[ $MODE == notify ]] && notify-send -a wd -t 3000 "查词" "无选中内容(手输用 Mod+Ctrl+D)"
    exit 0
fi
[[ $MODE != cli ]] && printf '%s' "$q" > "$MEMO"

if [[ "$q" == *' '* ]]; then
    r="$(lookup_online "$q")"
    show "$q" "${r:-在线翻译不可达(查网络/节点)}"
elif r="$(lookup_offline "$q")"; then
    show "$q" "$r"
else
    r="$(lookup_online "$q")"
    show "$q" "${r:-词典未收录,且在线不可达}"
fi
